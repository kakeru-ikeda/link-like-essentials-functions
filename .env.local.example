# Firebase Emulator設定
# エミュレータを使用する場合、これらの環境変数を設定します
FIRESTORE_EMULATOR_HOST=localhost:8080
FIREBASE_AUTH_EMULATOR_HOST=localhost:9099

# 開発環境用のプロジェクトID
GCLOUD_PROJECT=link-like-essentials

# AI エンジン（Cloud Run: lles-llm-engine）設定
# ローカル開発時は Ollama をローカルで動かす場合のデフォルト値を使用
OLLAMA_BASE_URL=https://lles-llm-engine-xxxxxxxxxx-an.a.run.app
OLLAMA_MODEL=gemma4:e4b

# GitHub Fine-grained PAT（Contents: Read-only）— プロンプト外部化用
# ローカル開発時は空のままでOK（ローカルファイル functions/prompts/card-filter-query.txt から読み込む）
# 本番環境では Firebase Secret Manager の GITHUB_PAT に設定すること
GITHUB_PAT=
